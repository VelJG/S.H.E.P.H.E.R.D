ZONE_REFRESH_SEC=10
METRICS_POST_INTERVAL_SEC=1
INCIDENT_COOLDOWN_SEC=60
EVIDENCE_UPLOAD_ENABLED=true
ZONES_FILE=
TRACK_FRAME_RATE=30

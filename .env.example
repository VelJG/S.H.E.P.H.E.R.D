MODEL_NAME=yolo26s.pt
MODEL_PATH=/models/yolo26s.pt
IMG_SIZE=640
CONF_THRES=0.25
DEVICE=auto
SHEPHERD_MODEL_DIR=D:/AI_Data/SHEPHERD/models/yolo
SHEPHERD_YOLO_CACHE_DIR=D:/AI_Data/SHEPHERD/cache/ultralytics
SHEPHERD_RUNS_DIR=D:/AI_Data/SHEPHERD/runs
